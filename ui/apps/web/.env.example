# Copy to `.env`.
#
# SAME-ORIGIN BFF (decision D3): the browser talks ONLY to this web app's own
# origin under `/api/agent`. A Next.js route handler proxies those calls to the
# agent, attaching a GCP OIDC token in production. There is NO NEXT_PUBLIC_API_URL
# anymore — the agent URL is a SERVER-SIDE runtime var, never baked into the JS
# bundle. This keeps a single web image promotable from dev to prod.

# Server-side only: the agent's base URL the proxy forwards to.
# - Local dev: point at the LangGraph dev server.
# - Cloud Run: Terraform injects the agent's internal Cloud Run URL at runtime
#   (do NOT commit it here). When AGENT_URL is an https Cloud Run URL the proxy
#   mints an OIDC ID token (audience = AGENT_URL) for the private agent.
AGENT_URL=http://localhost:2024

# Fixed assistant / graph id (shared convention). Override only for a non-default
# graph id. This is safe to expose; it carries no environment-specific secret.
NEXT_PUBLIC_ASSISTANT_ID=agent

# Optional: only needed when connecting to a deployed/LangSmith agent that
# requires an API key. Forwarded by the proxy as the X-Api-Key header.
# NEXT_PUBLIC_LANGSMITH_API_KEY=
