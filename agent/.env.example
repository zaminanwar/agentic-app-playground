# Copy to `.env` and fill in your values.

# --- Gemini via Vertex AI (recommended on GCP) ---
# Uses Application Default Credentials. Run once locally:
#   gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# --- Alternative: Gemini via the public API (no GCP needed) ---
# To use this instead, change the model in agent.py to
# "google_genai:gemini-2.5-flash" and set:
# GOOGLE_API_KEY=your-api-key

# --- RFP document storage (Google Cloud Storage) ---
# Bucket holding uploaded RFP PDFs. The web upload route writes objects here and
# hands the agent a gs:// pointer; `ingest_rfp` downloads and parses it. Without
# it (or without GCP credentials) ingestion degrades to a clear message instead
# of failing. In deployed envs Terraform provisions the bucket and injects this
# name into both services — see infra/.
# RFP_BUCKET=your-rfp-docs-bucket

# --- Self-hosted Agent Server persistence (REQUIRED in deployed/prod envs) ---
# These are consumed by the self-hosted production Agent Server, which injects a
# durable checkpointer/store itself — agent.py stays checkpointer-free. Local
# `langgraph dev` uses an in-memory store and ignores these. In Cloud Run both
# are injected by Terraform / Secret Manager (NOT committed). See infra/.
#
# Cloud SQL Postgres (durable checkpointer + store):
# DATABASE_URI=postgresql://user:password@/dbname?host=/cloudsql/<connection_name>
#
# Memorystore Redis (task queue / pub-sub) — MANDATORY: the standalone server
# cannot run Postgres-only. Reaching private Memorystore from Cloud Run needs
# VPC access (Direct VPC egress or a Serverless VPC connector), set up in infra/.
# REDIS_URI=redis://<memorystore-host>:6379

# --- Self-hosted Agent Server LICENSE (REQUIRED in prod) ---
# The standalone production server validates a LangGraph Platform license at
# startup (and periodically) and will NOT start without it. Supply ONE of these
# via Secret Manager in Cloud Run (it also egresses to beacon.langchain.com for
# verification unless you hold an air-gapped key):
# LANGGRAPH_CLOUD_LICENSE_KEY=your-langgraph-platform-license-key
# LANGSMITH_API_KEY=your-langsmith-key   # alternative: validated against LangSmith SaaS

# --- Optional: LangSmith tracing (paid plan) ---
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your-langsmith-key
