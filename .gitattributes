# Normalize line endings: store LF in the repo (correct for Linux CI/Docker),
# regardless of each developer's core.autocrlf setting.
* text=auto eol=lf

# Windows-native scripts keep CRLF on checkout.
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
